# Supabase / Postgres Connection
# Use the Direct Connection String from Supabase -> Settings -> Database
DATABASE_URL=postgresql://postgres:[YOUR-PASSWORD]@db.[YOUR-PROJECT-REF].supabase.co:5432/postgres

# Alternatively, if you want to use the API (not recommended for pg pool but good to have)
SUPABASE_URL=https://[YOUR-PROJECT-REF].supabase.co
SUPABASE_ANON_KEY=[YOUR-ANON-KEY]

# Server Configuration
PORT=5000
JWT_SECRET=your_jwt_secret_key_here

# Initial Admin Credentials (used by seeder)
ADMIN_EMAIL=admin@hekimika.org
ADMIN_PASSWORD=your_secure_password
ADMIN_NAME=Hekimika Admin

# CORS / Frontend URL
CLIENT_URL=http://localhost:5173
FRONTEND_URL=https://your-site.netlify.app
